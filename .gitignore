# Sample dataset: only the raw inputs under 0_input/ and the final top-level
# *_labels.tif are tracked, so the pipeline can be run end-to-end from a fresh
# clone. Everything else is derived and stays out: Cellpose intermediates, the
# per-stage working folders (whose tracked_labels.tif are byte-identical copies
# of the top-level labels), and the contact analysis outputs (which also embed
# absolute paths in their provenance group).
sample_data/**/1_cellpose/
sample_data/**/2_nucleus/
sample_data/**/3_cell/
sample_data/**/ultrack_workdir/
sample_data/**/*.h5
!sample_data/**/*.tif
